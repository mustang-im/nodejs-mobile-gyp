{
  "name": "nodejs-mobile-gyp",
  "description": "Node.js for Mobile Apps native addon build tool",
  "license": "MIT",
  "keywords": [
    "nodejs-mobile",
    "native",
    "addon",
    "module",
    "c",
    "c++",
    "bindings",
    "gyp"
  ],
  "version": "0.4.0",
  "installVersion": 11,
  "author": "janeasystems",
  "homepage": "https://code.janeasystems.com/nodejs-mobile",
  "repository": {
    "type": "git",
    "url": "git://github.com/janeasystems/nodejs-mobile-gyp.git"
  },
  "preferGlobal": true,
  "bin": "./bin/node-gyp.js",
  "main": "./lib/node-gyp.js",
  "dependencies": {
    "env-paths": "^2.2.0",
    "exponential-backoff": "^3.1.1",
    "graceful-fs": "^4.2.6",
    "make-fetch-happen": "^14.0.3",
    "nopt": "^8.0.0",
    "proc-log": "^5.0.0",
    "semver": "^7.3.5",
    "tar": "^7.4.3",
    "tinyglobby": "^0.2.12",
    "which": "^5.0.0"
  },
  "engines": {
    "node": "^18.17.0 || >=20.5.0"
  },
  "devDependencies": {
    "bindings": "^1.5.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.16.0",
    "mocha": "^11.0.1",
    "nan": "^2.14.2",
    "neostandard": "^0.11.9",
    "require-inject": "^1.4.4"
  },
  "scripts": {
    "lint": "eslint \"*/*.js\" \"test/**/*.js\" \".github/**/*.js\"",
    "test": "cross-env NODE_GYP_NULL_LOGGER=true mocha --timeout 15000 test/test-download.js test/test-*"
  }
}
